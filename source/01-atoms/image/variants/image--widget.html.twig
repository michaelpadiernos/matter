{#
/**
 * @file
 * Default theme implementation for an image field widget.
 *
 * Available variables:
 * - attributes: HTML attributes for the containing element.
 * - data: Render elements of the image widget.
 *
 * @see \Drupal\image\Hook\ImageThemeHooks::preprocessImageWidget()
 *
 * @ingroup themeable
 */
#}
{% extends "@atoms/image/image.html.twig" %}

{% block image %}

  <div{{ attributes }}>

    {% if data.preview %}
      {% include '@atoms/image/variants/image--preview.html.twig' %}
    {% endif %}

    {# Render widget data without the image preview that was output already. #}
    {{ data|without('preview') }}
  </div>

{% endblock %}
