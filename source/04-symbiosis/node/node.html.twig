{#
/**
 * @file
 * Custom theme implementation to display a node.
 * Starlight default for all nodes not in "full" view mode
 *
 * Documentation here: https://api.drupal.org/api/drupal/core!modules!node!templates!node.html.twig/8.2.x
 *
 * @ingroup themeable
 */
#}

{% block node %}

  {%
    set classes = [
      'node',
      node.bundle|clean_class,
      view_mode ? view_mode|clean_class,
      'grid',
      'grid-content'
    ]
  %}

  <article{{ attributes.addClass(classes) }}>

    {% include '@organisms/node_item/variants/node-item--header.html.twig' %}

    {% include '@organisms/node_item/variants/node-item--content.html.twig' %}

    {% include '@organisms/node_item/variants/node-item--footer.html.twig' %}

  </article>

{% endblock %}
