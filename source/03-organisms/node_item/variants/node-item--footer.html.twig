{% extends '@organisms/node_item/node-item.html.twig' %}

{% block node_item %}

  {%
    set classes = [
      'node-item',
      'node-item--footer',
      'content-footer',
      'grid',
    ]
  %}

  {% if content.links %}
    <footer{{ attributes.addClass(classes) }}>
      {{ content.links }}
    </footer>
  {% endif %}

{% endblock %}
